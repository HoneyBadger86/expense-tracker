<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Expense Tracker</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <h1>Pencatatan Pengeluaran Harian</h1>

    <% if (error) { %>
      <div class="alert" data-testid="error-message"><%= error %></div>
    <% } %>

    <section class="card">
      <h2>Tambah Pengeluaran</h2>
      <form method="POST" action="/expenses">
        <div class="form-row">
          <label for="amount">Nominal (Rp)</label>
          <input type="number" id="amount" name="amount">
        </div>
        <div class="form-row">
          <label for="category">Kategori</label>
          <select id="category" name="category">
            <option value="">-- Pilih Kategori --</option>
            <% categories.forEach(function(cat) { %>
              <option value="<%= cat %>"><%= cat %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-row">
          <label for="date">Tanggal</label>
          <input type="date" id="date" name="date">
        </div>
        <div class="form-row">
          <label for="note">Catatan</label>
          <input type="text" id="note" name="note" placeholder="Opsional">
        </div>
        <button type="submit" data-testid="submit-add">Tambah</button>
      </form>
    </section>

    <section class="card">
      <h2>Filter</h2>
      <form method="GET" action="/">
        <div class="form-row">
          <label for="filter-category">Kategori</label>
          <select id="filter-category" name="category">
            <option value="">Semua Kategori</option>
            <% categories.forEach(function(cat) { %>
              <option value="<%= cat %>" <%= filters.category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-row">
          <label for="dateFrom">Dari Tanggal</label>
          <input type="date" id="dateFrom" name="dateFrom" value="<%= filters.dateFrom %>">
        </div>
        <div class="form-row">
          <label for="dateTo">Sampai Tanggal</label>
          <input type="date" id="dateTo" name="dateTo" value="<%= filters.dateTo %>">
        </div>
        <button type="submit" data-testid="submit-filter">Terapkan Filter</button>
      </form>
    </section>

    <section class="card">
      <h2>Daftar Pengeluaran</h2>
      <p class="total" data-testid="total-amount">Total: Rp <%= total.toLocaleString('id-ID') %></p>
      <table data-testid="expense-table">
        <thead>
          <tr>
            <th>Tanggal</th>
            <th>Kategori</th>
            <th>Nominal</th>
            <th>Catatan</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (expenses.length === 0) { %>
            <tr><td colspan="5" class="empty" data-testid="empty-row">Belum ada data pengeluaran</td></tr>
          <% } %>
          <% expenses.forEach(function(exp) { %>
            <tr class="expense-row" data-testid="expense-row" data-id="<%= exp.id %>">
              <td><%= exp.date %></td>
              <td><%= exp.category %></td>
              <td>Rp <%= exp.amount.toLocaleString('id-ID') %></td>
              <td><%= exp.note %></td>
              <td>
                <form method="POST" action="/expenses/<%= exp.id %>/delete">
                  <button type="submit" data-testid="delete-btn">Hapus</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </div>
</body>
</html>
