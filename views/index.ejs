<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Expense Tracker</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>

  <header class="hero">
    <p class="eyebrow">✨ money, but make it fun</p>
    <h1>Duit Kemana Aja? 💸</h1>
    <p class="tagline">Catat pengeluaran harianmu tanpa drama.</p>
  </header>

  <main class="wrap">
    <div class="grid-2 stat-grid">
      <div class="stat-card">
        <span class="stat-emoji">🪙</span>
        <div>
          <p class="stat-label">Total Pengeluaran</p>
          <p class="stat-value" data-testid="total-amount">Rp <%= total.toLocaleString('id-ID') %></p>
        </div>
      </div>

      <div class="stat-card budget-card">
        <span class="stat-emoji">🎯</span>
        <div class="budget-body">
          <p class="stat-label">Budget Bulan Ini</p>
          <% if (budget.limit > 0) { %>
            <p class="budget-text" data-testid="budget-text">
              Rp <%= budget.spent.toLocaleString('id-ID') %> / Rp <%= budget.limit.toLocaleString('id-ID') %>
            </p>
            <div class="progress-track">
              <div class="progress-fill progress-<%= budget.state %>" data-testid="budget-progress" style="width: <%= budget.percent %>%"></div>
            </div>
            <% if (budget.state === 'over') { %>
              <p class="budget-note budget-note-over" data-testid="budget-note">Budget bulan ini sudah terlampaui!</p>
            <% } else if (budget.state === 'warn') { %>
              <p class="budget-note budget-note-warn" data-testid="budget-note">Hati-hati, budget hampir habis.</p>
            <% } %>
          <% } else { %>
            <p class="budget-text" data-testid="budget-text">Belum diatur</p>
          <% } %>
          <form method="POST" action="/budget" class="budget-form">
            <input type="number" name="monthlyBudget" placeholder="cth. 2000000" value="<%= budget.limit > 0 ? budget.limit : '' %>">
            <button type="submit" class="btn-funky btn-small" data-testid="submit-budget">Simpan</button>
          </form>
        </div>
      </div>
    </div>

    <% if (error) { %>
      <div class="alert-funky" data-testid="error-message">🚨 <%= error %></div>
    <% } %>

    <div class="grid-2">
      <section class="card">
        <h2>➕ Tambah Pengeluaran</h2>
        <form method="POST" action="/expenses">
          <label for="amount">Nominal (Rp)</label>
          <input type="number" id="amount" name="amount" placeholder="cth. 50000">

          <label for="category">Kategori</label>
          <select id="category" name="category">
            <option value="">-- Pilih Kategori --</option>
            <% categories.forEach(function(cat) { %>
              <option value="<%= cat %>"><%= cat %></option>
            <% }) %>
          </select>

          <label for="date">Tanggal</label>
          <input type="date" id="date" name="date">

          <label for="note">Catatan</label>
          <input type="text" id="note" name="note" placeholder="Opsional">

          <button type="submit" class="btn-funky" data-testid="submit-add">Tambah</button>
        </form>
      </section>

      <section class="card">
        <h2>🔍 Filter</h2>
        <form method="GET" action="/">
          <label for="filter-category">Kategori</label>
          <select id="filter-category" name="category">
            <option value="">Semua Kategori</option>
            <% categories.forEach(function(cat) { %>
              <option value="<%= cat %>" <%= filters.category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>

          <div class="row-2">
            <div>
              <label for="dateFrom">Dari</label>
              <input type="date" id="dateFrom" name="dateFrom" value="<%= filters.dateFrom %>">
            </div>
            <div>
              <label for="dateTo">Sampai</label>
              <input type="date" id="dateTo" name="dateTo" value="<%= filters.dateTo %>">
            </div>
          </div>

          <button type="submit" class="btn-funky btn-outline" data-testid="submit-filter">Terapkan Filter</button>
        </form>
      </section>
    </div>

    <section class="card">
      <h2>📊 Pengeluaran per Kategori</h2>
      <% if (Object.keys(categorySummary).length === 0) { %>
        <p class="chart-empty" data-testid="chart-empty">Belum ada data untuk digambar 🎨</p>
      <% } else { %>
        <div class="chart-box">
          <canvas id="categoryChart" data-testid="category-chart"></canvas>
        </div>
      <% } %>
    </section>

    <section class="card card-list">
      <h2>📒 Daftar Pengeluaran</h2>
      <div class="table-scroll">
        <table data-testid="expense-table">
          <thead>
            <tr>
              <th>Tanggal</th>
              <th>Kategori</th>
              <th>Nominal</th>
              <th>Catatan</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if (expenses.length === 0) { %>
              <tr class="empty-row">
                <td colspan="5" data-testid="empty-row">Belum ada cerita pengeluaran di sini ✍️</td>
              </tr>
            <% } %>
            <% var chip = {
              Makanan: { emoji: '🍔', color: 'chip-orange' },
              Transportasi: { emoji: '🚗', color: 'chip-blue' },
              Belanja: { emoji: '🛍️', color: 'chip-pink' },
              Tagihan: { emoji: '🧾', color: 'chip-slate' },
              Hiburan: { emoji: '🎉', color: 'chip-green' },
              Lainnya: { emoji: '📦', color: 'chip-yellow' }
            }; %>
            <% expenses.forEach(function(exp) { %>
              <% var c = chip[exp.category] || { emoji: '💰', color: 'chip-slate' }; %>
              <tr class="expense-row" data-testid="expense-row" data-id="<%= exp.id %>">
                <td><%= exp.date %></td>
                <td><span class="chip <%= c.color %>"><%= c.emoji %> <%= exp.category %></span></td>
                <td class="amount">Rp <%= exp.amount.toLocaleString('id-ID') %></td>
                <td><%= exp.note %></td>
                <td>
                  <div class="row-actions">
                    <a href="/expenses/<%= exp.id %>/edit" class="btn-icon btn-icon-edit" data-testid="edit-btn">✏️</a>
                    <form method="POST" action="/expenses/<%= exp.id %>/delete">
                      <button type="submit" class="btn-icon" data-testid="delete-btn">🗑️</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <footer class="foot">made with ☕ + a few 🐛 fixes</footer>

  <% if (Object.keys(categorySummary).length > 0) { %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.9/dist/chart.umd.min.js"></script>
    <script>
      const summary = <%- JSON.stringify(categorySummary) %>;
      const palette = {
        Makanan: '#f97316',
        Transportasi: '#3b82f6',
        Belanja: '#ec4899',
        Tagihan: '#64748b',
        Hiburan: '#22c55e',
        Lainnya: '#eab308'
      };
      const labels = Object.keys(summary);
      new Chart(document.getElementById('categoryChart'), {
        type: 'doughnut',
        data: {
          labels: labels,
          datasets: [{
            data: labels.map(function (l) { return summary[l]; }),
            backgroundColor: labels.map(function (l) { return palette[l] || '#a78bfa'; }),
            borderWidth: 3,
            borderColor: '#ffffff'
          }]
        },
        options: {
          maintainAspectRatio: false,
          plugins: {
            legend: { position: 'right', labels: { font: { family: 'Inter' }, usePointStyle: true } },
            tooltip: {
              callbacks: {
                label: function (ctx) {
                  return ctx.label + ': Rp ' + ctx.parsed.toLocaleString('id-ID');
                }
              }
            }
          }
        }
      });
    </script>
  <% } %>
</body>
</html>
