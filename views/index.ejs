<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Expense Tracker</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>

  <header class="hero">
    <p class="eyebrow"><i class="fa-solid fa-wand-magic-sparkles"></i> money, but make it fun</p>
    <h1>Duit Kemana Aja? <i class="fa-solid fa-money-bill-wave hero-icon"></i></h1>
    <p class="tagline">Catat pengeluaran harianmu tanpa drama.</p>
  </header>

  <main class="wrap">
    <% if (error) { %>
      <div class="alert-funky" data-testid="error-message"><i class="fa-solid fa-triangle-exclamation"></i> <%= error %></div>
    <% } %>

    <div class="grid-2 stat-grid">
      <div class="stat-card">
        <span class="stat-emoji icon-violet"><i class="fa-solid fa-coins"></i></span>
        <div>
          <p class="stat-label">Total Pengeluaran</p>
          <p class="stat-value" data-testid="total-amount">Rp <%= total.toLocaleString('id-ID') %></p>
        </div>
      </div>

      <div class="stat-card">
        <span class="stat-emoji icon-green"><i class="fa-solid fa-sack-dollar"></i></span>
        <div>
          <p class="stat-label">Pemasukan Bulan Ini</p>
          <p class="stat-value stat-income" data-testid="income-total">Rp <%= incomeThisMonth.toLocaleString('id-ID') %></p>
        </div>
      </div>

      <div class="stat-card">
        <span class="stat-emoji icon-amber"><i class="fa-solid fa-scale-balanced"></i></span>
        <div>
          <p class="stat-label">Saldo Bulan Ini</p>
          <p class="stat-value <%= balance < 0 ? 'stat-negative' : 'stat-income' %>" data-testid="balance-amount">
            Rp <%= balance.toLocaleString('id-ID') %>
          </p>
        </div>
      </div>

      <div class="stat-card budget-card">
        <span class="stat-emoji icon-pink"><i class="fa-solid fa-bullseye"></i></span>
        <div class="budget-body">
          <p class="stat-label">Budget Bulan Ini</p>
          <% if (budget.limit > 0) { %>
            <p class="budget-text" data-testid="budget-text">
              Rp <%= budget.spent.toLocaleString('id-ID') %> / Rp <%= budget.limit.toLocaleString('id-ID') %>
            </p>
            <div class="progress-track">
              <div class="progress-fill progress-<%= budget.state %>" data-testid="budget-progress" style="width: <%= budget.percent %>%"></div>
            </div>
            <% if (budget.state === 'over') { %>
              <p class="budget-note budget-note-over" data-testid="budget-note">Budget bulan ini sudah terlampaui!</p>
            <% } else if (budget.state === 'warn') { %>
              <p class="budget-note budget-note-warn" data-testid="budget-note">Hati-hati, budget hampir habis.</p>
            <% } %>
          <% } else { %>
            <p class="budget-text" data-testid="budget-text">Belum diatur</p>
          <% } %>
          <form method="POST" action="/budget" class="budget-form">
            <input type="number" name="monthlyBudget" placeholder="cth. 2000000" value="<%= budget.limit > 0 ? budget.limit : '' %>">
            <button type="submit" class="btn-funky btn-small" data-testid="submit-budget">Simpan</button>
          </form>
        </div>
      </div>
    </div>

    <div class="grid-2">
      <section class="card">
        <h2><i class="fa-solid fa-circle-minus"></i> Tambah Pengeluaran</h2>
        <form method="POST" action="/expenses">
          <label for="amount">Nominal (Rp)</label>
          <input type="number" id="amount" name="amount" placeholder="cth. 50000">

          <label for="category">Kategori</label>
          <select id="category" name="category">
            <option value="">-- Pilih Kategori --</option>
            <% categories.forEach(function(cat) { %>
              <option value="<%= cat %>"><%= cat %></option>
            <% }) %>
          </select>

          <label for="date">Tanggal</label>
          <input type="date" id="date" name="date">

          <label for="note">Catatan</label>
          <input type="text" id="note" name="note" placeholder="Opsional">

          <button type="submit" class="btn-funky" data-testid="submit-add">Tambah</button>
        </form>
      </section>

      <section class="card">
        <h2><i class="fa-solid fa-circle-plus"></i> Tambah Pemasukan</h2>
        <form method="POST" action="/incomes">
          <label for="i-amount">Nominal (Rp)</label>
          <input type="number" id="i-amount" name="amount" placeholder="cth. 1000000">

          <label for="i-date">Tanggal</label>
          <input type="date" id="i-date" name="date">

          <label for="i-note">Catatan</label>
          <input type="text" id="i-note" name="note" placeholder="cth. Gaji, bonus, THR">

          <button type="submit" class="btn-funky btn-income" data-testid="submit-income">Tambah</button>
        </form>
      </section>
    </div>

    <section class="card">
      <h2><i class="fa-solid fa-filter"></i> Filter Pengeluaran</h2>
      <form method="GET" action="/" class="filter-inline">
        <div class="filter-field">
          <label for="filter-category">Kategori</label>
          <select id="filter-category" name="category">
            <option value="">Semua Kategori</option>
            <% categories.forEach(function(cat) { %>
              <option value="<%= cat %>" <%= filters.category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
        </div>
        <div class="filter-field">
          <label for="dateFrom">Dari</label>
          <input type="date" id="dateFrom" name="dateFrom" value="<%= filters.dateFrom %>">
        </div>
        <div class="filter-field">
          <label for="dateTo">Sampai</label>
          <input type="date" id="dateTo" name="dateTo" value="<%= filters.dateTo %>">
        </div>
        <button type="submit" class="btn-funky btn-small" data-testid="submit-filter">Terapkan Filter</button>
      </form>
    </section>

    <div class="grid-2">
      <section class="card">
        <h2><i class="fa-solid fa-chart-pie"></i> Pengeluaran per Kategori</h2>
        <% if (Object.keys(categorySummary).length === 0) { %>
          <p class="chart-empty" data-testid="chart-empty">Belum ada data untuk digambar</p>
        <% } else { %>
          <div class="chart-box">
            <canvas id="categoryChart" data-testid="category-chart"></canvas>
          </div>
        <% } %>
      </section>

      <section class="card">
        <h2><i class="fa-solid fa-chart-column"></i> Tren 6 Bulan Terakhir</h2>
        <div class="chart-box">
          <canvas id="trendChart" data-testid="trend-chart"></canvas>
        </div>
      </section>
    </div>

    <section class="card card-list">
      <div class="list-head">
        <h2><i class="fa-solid fa-list"></i> Daftar Pengeluaran</h2>
        <div class="export-actions">
          <a href="/export/xlsx?category=<%= encodeURIComponent(filters.category) %>&dateFrom=<%= filters.dateFrom %>&dateTo=<%= filters.dateTo %>"
             class="btn-funky btn-small" data-testid="export-xlsx"><i class="fa-solid fa-file-excel"></i> Export Excel</a>
          <a href="/export/csv?category=<%= encodeURIComponent(filters.category) %>&dateFrom=<%= filters.dateFrom %>&dateTo=<%= filters.dateTo %>"
             class="btn-funky btn-small btn-outline" data-testid="export-csv">Export CSV</a>
        </div>
      </div>
      <div class="table-scroll">
        <table data-testid="expense-table">
          <thead>
            <tr>
              <th>Tanggal</th>
              <th>Kategori</th>
              <th>Nominal</th>
              <th>Catatan</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if (expenses.length === 0) { %>
              <tr class="empty-row">
                <td colspan="5" data-testid="empty-row">Belum ada cerita pengeluaran di sini</td>
              </tr>
            <% } %>
            <% var chip = {
              Makanan: { icon: 'fa-burger', color: 'chip-orange' },
              Transportasi: { icon: 'fa-car', color: 'chip-blue' },
              Belanja: { icon: 'fa-bag-shopping', color: 'chip-pink' },
              Tagihan: { icon: 'fa-file-invoice', color: 'chip-slate' },
              Hiburan: { icon: 'fa-gamepad', color: 'chip-green' },
              Lainnya: { icon: 'fa-box', color: 'chip-yellow' }
            }; %>
            <% expenses.forEach(function(exp) { %>
              <% var c = chip[exp.category] || { icon: 'fa-money-bill', color: 'chip-slate' }; %>
              <tr class="expense-row" data-testid="expense-row" data-id="<%= exp.id %>">
                <td><%= exp.date %></td>
                <td><span class="chip <%= c.color %>"><i class="fa-solid <%= c.icon %>"></i> <%= exp.category %></span></td>
                <td class="amount">Rp <%= exp.amount.toLocaleString('id-ID') %></td>
                <td><%= exp.note %></td>
                <td>
                  <div class="row-actions">
                    <a href="/expenses/<%= exp.id %>/edit" class="btn-icon btn-icon-edit" data-testid="edit-btn"><i class="fa-solid fa-pen"></i></a>
                    <form method="POST" action="/expenses/<%= exp.id %>/delete" onsubmit="return confirm('Hapus pengeluaran ini?')">
                      <button type="submit" class="btn-icon" data-testid="delete-btn"><i class="fa-solid fa-trash"></i></button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="card card-list">
      <h2><i class="fa-solid fa-briefcase"></i> Daftar Pemasukan</h2>
      <div class="table-scroll">
        <table data-testid="income-table">
          <thead>
            <tr>
              <th>Tanggal</th>
              <th>Nominal</th>
              <th>Catatan</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if (incomes.length === 0) { %>
              <tr class="empty-row">
                <td colspan="4" data-testid="income-empty-row">Belum ada pemasukan tercatat</td>
              </tr>
            <% } %>
            <% incomes.forEach(function(inc) { %>
              <tr class="expense-row" data-testid="income-row" data-id="<%= inc.id %>">
                <td><%= inc.date %></td>
                <td class="amount amount-in">Rp <%= inc.amount.toLocaleString('id-ID') %></td>
                <td><%= inc.note %></td>
                <td>
                  <form method="POST" action="/incomes/<%= inc.id %>/delete" onsubmit="return confirm('Hapus pemasukan ini?')">
                    <button type="submit" class="btn-icon" data-testid="income-delete-btn"><i class="fa-solid fa-trash"></i></button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <footer class="foot">made with <i class="fa-solid fa-mug-hot"></i> + a few <i class="fa-solid fa-bug"></i> fixes</footer>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.9/dist/chart.umd.min.js"></script>
  <script>
    const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Okt', 'Nov', 'Des'];

    const summary = <%- JSON.stringify(categorySummary) %>;
    if (Object.keys(summary).length > 0) {
      const palette = {
        Makanan: '#f97316',
        Transportasi: '#3b82f6',
        Belanja: '#ec4899',
        Tagihan: '#64748b',
        Hiburan: '#22c55e',
        Lainnya: '#eab308'
      };
      const labels = Object.keys(summary);
      new Chart(document.getElementById('categoryChart'), {
        type: 'doughnut',
        data: {
          labels: labels,
          datasets: [{
            data: labels.map(function (l) { return summary[l]; }),
            backgroundColor: labels.map(function (l) { return palette[l] || '#a78bfa'; }),
            borderWidth: 3,
            borderColor: '#ffffff'
          }]
        },
        options: {
          maintainAspectRatio: false,
          plugins: {
            legend: { position: 'right', labels: { font: { family: 'Inter' }, usePointStyle: true } },
            tooltip: {
              callbacks: {
                label: function (ctx) {
                  return ctx.label + ': Rp ' + ctx.parsed.toLocaleString('id-ID');
                }
              }
            }
          }
        }
      });
    }

    const trend = <%- JSON.stringify(trend) %>;
    new Chart(document.getElementById('trendChart'), {
      type: 'bar',
      data: {
        labels: trend.map(function (t) {
          const parts = t.month.split('-');
          return monthNames[Number(parts[1]) - 1] + ' ' + parts[0];
        }),
        datasets: [{
          data: trend.map(function (t) { return t.total; }),
          backgroundColor: 'rgba(124, 58, 237, 0.7)',
          borderRadius: 8
        }]
      },
      options: {
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function (ctx) {
                return 'Rp ' + ctx.parsed.y.toLocaleString('id-ID');
              }
            }
          }
        },
        scales: {
          y: {
            ticks: {
              callback: function (value) {
                return value >= 1000000 ? (value / 1000000) + 'jt' : value >= 1000 ? (value / 1000) + 'rb' : value;
              }
            }
          }
        }
      }
    });
  </script>
</body>
</html>
