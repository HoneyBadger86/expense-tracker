<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Edit Pengeluaran</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>

  <header class="hero">
    <h1>Edit Pengeluaran <i class="fa-solid fa-pen hero-icon"></i></h1>
    <p class="tagline">Salah catat? Santai, benerin di sini.</p>
  </header>

  <main class="wrap wrap-narrow">
    <% if (error) { %>
      <div class="alert-funky" data-testid="error-message"><i class="fa-solid fa-triangle-exclamation"></i> <%= error %></div>
    <% } %>

    <section class="card">
      <form method="POST" action="/expenses/<%= expense.id %>/update">
        <label for="amount">Nominal (Rp)</label>
        <input type="number" id="amount" name="amount" value="<%= expense.amount %>">

        <label for="category">Kategori</label>
        <select id="category" name="category">
          <option value="">-- Pilih Kategori --</option>
          <% categories.forEach(function(cat) { %>
            <option value="<%= cat %>" <%= expense.category === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>

        <label for="date">Tanggal</label>
        <input type="date" id="date" name="date" value="<%= expense.date %>">

        <label for="note">Catatan</label>
        <input type="text" id="note" name="note" value="<%= expense.note %>" placeholder="Opsional">

        <button type="submit" class="btn-funky" data-testid="submit-update">Simpan Perubahan</button>
        <a href="/" class="btn-funky btn-outline btn-link" data-testid="cancel-edit">Batal</a>
      </form>
    </section>
  </main>

  <footer class="foot">made with ☕ + a few 🐛 fixes</footer>
</body>
</html>
